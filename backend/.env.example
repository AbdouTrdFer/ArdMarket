PORT=4000
JWT_SECRET=change-me-in-production
DATABASE_PATH=./data/ardmarket.sqlite
UPLOADS_DIR=./uploads
# Optionnel — active l'extraction IA réelle (sinon fallback stub)
# OPENAI_API_KEY=sk-...

# Firebase (chatbot Telegram darija)
# Placer le service account JSON dans backend/secrets/firebase-service-account.json
# OU spécifier un chemin custom :
# FIREBASE_SERVICE_ACCOUNT_PATH=/abs/path/to/service-account.json
# Auto-sync toutes les N minutes (0 = désactivé). Défaut: 5
# FIREBASE_AUTOSYNC_INTERVAL_MIN=5
